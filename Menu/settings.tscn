[node name="Label" type="Label" parent="SettingsPanel/SettingsTabs/Help/MarginContainer/ScrollContainer/MarginContainer/ElementList/HelpList/SubSectionElements" unique_id=1664352015]
layout_mode = 2
theme_override_constants/line_spacing = 0
text = "Threw your revolver and can't find it? There are revolver spawners. They are located by enemy spawn points and scattered around the map.

My bullets aren't hurting the enemy? That means you have unfortunatly received the healing bullet from your latest roulette attempt. Complete the wave using your fist (see controls).

* There are likely some bugs since this was made for a game jam. 

Thank you for playing :)"
autowrap_mode = 2

